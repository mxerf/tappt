{
  "name": "@mxerf/tappt",
  "version": "0.1.2",
  "description": "Tiny, SSR-safe haptic feedback for the web. Works in Telegram Mini Apps, iOS Safari 17.4+ (Taptic Engine via the switch hack), and anywhere the Vibration API is available. Framework adapters for React and Vue.",
  "keywords": [
    "haptic",
    "haptics",
    "vibration",
    "taptic",
    "ios",
    "telegram",
    "mini-app",
    "pwa",
    "react",
    "vue"
  ],
  "author": "mxerf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mxerf/tappt.git"
  },
  "homepage": "https://github.com/mxerf/tappt#readme",
  "bugs": {
    "url": "https://github.com/mxerf/tappt/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "^15.11.7",
    "react": "^19.0.0",
    "react-dom": "^19.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  },
  "publishConfig": {
    "access": "public"
  }
}
